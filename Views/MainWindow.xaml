<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="液压支架监控" Height="850" Width="1400" WindowStartupLocation="CenterScreen"
        TextElement.FontSize="14" 
        TextElement.FontWeight="Regular"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei">

	<Grid Margin="24">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="280"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Grid Grid.Column="0" Margin="0,0,24,0">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" Text="液压支架监控" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" VerticalAlignment="Center" HorizontalAlignment="Center"/>

			<Border Grid.Row="1" Margin="0,0,0,12" BorderBrush="#D1D1D1" BorderThickness="2" CornerRadius="8" Padding="16" Background="Transparent">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<TextBlock Grid.Row="0" Text="支架编号与状态" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
					<ListView Grid.Row="1" ItemsSource="{Binding SupportList}" SelectedItem="{Binding SelectedSupport}" BorderThickness="0" Background="Transparent">
						<ListView.View>
							<GridView>
								<GridViewColumn Header="状态" Width="65">
									<GridViewColumn.CellTemplate>
										<DataTemplate>
											<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
												<Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,8,0"/>
												<TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
											</StackPanel>
										</DataTemplate>
									</GridViewColumn.CellTemplate>
								</GridViewColumn>
								<GridViewColumn Header="支架编号" Width="140" DisplayMemberBinding="{Binding DisplayName}"/>
							</GridView>
						</ListView.View>
					</ListView>
				</Grid>
			</Border>

			<Border Grid.Row="2" BorderBrush="#D1D1D1" BorderThickness="2" CornerRadius="8" Padding="16" Background="Transparent">
				<StackPanel>
					<TextBlock Text="系统连接" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
					<TextBlock Text="{Binding SerialStatusText}" Foreground="{Binding SerialStatusColor}" FontWeight="SemiBold" Margin="0,0,0,8" Cursor="Hand" ToolTip="点击配置串口参数">
						<TextBlock.InputBindings>
							<MouseBinding MouseAction="LeftClick" Command="{Binding OpenSerialConfigCommand}"/>
						</TextBlock.InputBindings>
					</TextBlock>
					<TextBlock Text="{Binding DbStatusText}" Foreground="{Binding DbStatusColor}" FontWeight="SemiBold"/>
				</StackPanel>
			</Border>
		</Grid>

		<Grid Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="2*"/>
				<RowDefinition Height="1.6*"/>
			</Grid.RowDefinitions>

			<Grid Grid.Row="0" Margin="0,0,0,16">
				<TextBlock Text="{Binding ParameterStatusText}" Foreground="{Binding ParameterStatusColor}" VerticalAlignment="Center" FontWeight="SemiBold"/>
				<TextBlock Text="{Binding CurrentTime, StringFormat='当前时间 {0}'}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="Gray" FontSize="12"/>
			</Grid>

			<Grid Grid.Row="1" Margin="0,0,0,12">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="2*"/>
				</Grid.ColumnDefinitions>

				<Border Grid.Column="0" Margin="0,0,12,0" BorderBrush="#D1D1D1" BorderThickness="2" CornerRadius="8" Padding="16" Background="Transparent">
					<Grid>
						<TextBlock Text="压力 1" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Top" HorizontalAlignment="Left"/>
						<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
							<TextBlock Text="{Binding CurrentPressure1, StringFormat='{}{0:F1}'}" FontSize="40" FontWeight="SemiBold" HorizontalAlignment="Center"/>
							<TextBlock Text="MPa" FontSize="12" HorizontalAlignment="Center" Foreground="Gray"/>
							<lvc:CartesianChart Height="80" Width="140" Margin="0,12,0,0" DisableAnimations="True" Hoverable="False" DataTooltip="{x:Null}">
								<lvc:CartesianChart.Series>
									<lvc:LineSeries Values="{Binding SparklineValues1}" PointGeometry="{x:Null}" LineSmoothness="0.5" Stroke="#1E90FF" Fill="#331E90FF" StrokeThickness="2"/>
								</lvc:CartesianChart.Series>
								<lvc:CartesianChart.AxisX>
									<lvc:Axis ShowLabels="False">
										<lvc:Axis.Separator>
											<lvc:Separator StrokeThickness="0"/>
										</lvc:Axis.Separator>
									</lvc:Axis>
								</lvc:CartesianChart.AxisX>
								<lvc:CartesianChart.AxisY>
									<lvc:Axis ShowLabels="False">
										<lvc:Axis.Separator>
											<lvc:Separator StrokeThickness="0"/>
										</lvc:Axis.Separator>
									</lvc:Axis>
								</lvc:CartesianChart.AxisY>
							</lvc:CartesianChart>
						</StackPanel>
					</Grid>
				</Border>

				<Border Grid.Column="1" Margin="0,0,12,0" BorderBrush="#D1D1D1" BorderThickness="2" CornerRadius="8" Padding="16" Background="Transparent">
					<Grid>
						<TextBlock Text="压力 2" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Top" HorizontalAlignment="Left"/>
						<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
							<TextBlock Text="{Binding CurrentPressure2, StringFormat='{}{0:F1}'}" FontSize="40" FontWeight="SemiBold" HorizontalAlignment="Center"/>
							<TextBlock Text="MPa" FontSize="12" HorizontalAlignment="Center" Foreground="Gray"/>
							<lvc:CartesianChart Height="80" Width="140" Margin="0,12,0,0" DisableAnimations="True" Hoverable="False" DataTooltip="{x:Null}">
								<lvc:CartesianChart.Series>
									<lvc:LineSeries Values="{Binding SparklineValues2}" PointGeometry="{x:Null}" LineSmoothness="0.5" Stroke="#FFA500" Fill="#33FFA500" StrokeThickness="2"/>
								</lvc:CartesianChart.Series>
								<lvc:CartesianChart.AxisX>
									<lvc:Axis ShowLabels="False">
										<lvc:Axis.Separator>
											<lvc:Separator StrokeThickness="0"/>
										</lvc:Axis.Separator>
									</lvc:Axis>
								</lvc:CartesianChart.AxisX>
								<lvc:CartesianChart.AxisY>
									<lvc:Axis ShowLabels="False">
										<lvc:Axis.Separator>
											<lvc:Separator StrokeThickness="0"/>
										</lvc:Axis.Separator>
									</lvc:Axis>
								</lvc:CartesianChart.AxisY>
							</lvc:CartesianChart>
						</StackPanel>
					</Grid>
				</Border>

				<Border Grid.Column="2" Margin="0,0,12,0" BorderBrush="#D1D1D1" BorderThickness="2" CornerRadius="8" Padding="16" Background="Transparent">
					<Grid>
						<TextBlock Text="角度" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Top" HorizontalAlignment="Left"/>
						<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
							<TextBlock Text="{Binding CurrentAngle, StringFormat='{}{0:F1}'}" FontSize="40" FontWeight="SemiBold" HorizontalAlignment="Center"/>
							<TextBlock Text="°" FontSize="12" HorizontalAlignment="Center" Foreground="Gray"/>
							<lvc:Gauge Value="{Binding CurrentAngle}" From="0" To="1800" Height="80" Width="140" Margin="0,12,0,0" GaugeActiveFill="DeepSkyBlue" GaugeBackground="#E5E5E5" LabelsVisibility="Collapsed"/>
						</StackPanel>
					</Grid>
				</Border>

				<Border Grid.Column="3" Margin="0" BorderBrush="#D1D1D1" BorderThickness="2" CornerRadius="8" Padding="16" Background="Transparent">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>
						<TextBlock Grid.Row="0" Text="实时参数趋势" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
						<lvc:CartesianChart Grid.Row="1" AnimationsSpeed="0:0:0.2" DisableAnimations="True" Hoverable="False">
							<lvc:CartesianChart.Series>
								<lvc:LineSeries Title="Angle" Values="{Binding TrendAngleSeries}" ScalesYAt="0" PointGeometrySize="0" Stroke="#32CD32" Fill="Transparent" StrokeThickness="2"/>
								<lvc:LineSeries Title="Pressure 1" Values="{Binding TrendPressure1Series}" ScalesYAt="1" PointGeometrySize="0" Stroke="#1E90FF" Fill="Transparent" StrokeThickness="2"/>
								<lvc:LineSeries Title="Pressure 2" Values="{Binding TrendPressure2Series}" ScalesYAt="1" PointGeometrySize="0" Stroke="#FFA500" Fill="Transparent" StrokeThickness="2"/>
							</lvc:CartesianChart.Series>
							<lvc:CartesianChart.AxisX>
								<lvc:Axis Labels="{Binding TimeLabels}" LabelsRotation="-45" FontSize="12">
									<lvc:Axis.Separator>
										<lvc:Separator Step="2" StrokeThickness="0"/>
									</lvc:Axis.Separator>
								</lvc:Axis>
							</lvc:CartesianChart.AxisX>
							<lvc:CartesianChart.AxisY>
								<lvc:Axis Title="角度 (°)" Foreground="#32CD32" LabelFormatter="{Binding YAxisFormatter}" MinValue="0" MaxValue="1800" FontSize="12"/>
								<lvc:Axis Title="压力 (MPa)" Foreground="Gray" Position="RightTop" LabelFormatter="{Binding YAxisFormatter}" MinValue="0" MaxValue="500" FontSize="12"/>
							</lvc:CartesianChart.AxisY>
						</lvc:CartesianChart>
					</Grid>
				</Border>
			</Grid>

			<Grid Grid.Row="2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="2*"/>
				</Grid.ColumnDefinitions>

				<Border Grid.Column="0" Margin="0,0,12,0" BorderBrush="#D1D1D1" BorderThickness="2" CornerRadius="8" Padding="16" Background="Transparent">
					<StackPanel>
						<TextBlock Text="控制中心" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

						<Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
							<Button Content="紧急停止" Background="#C62828" Foreground="White" FontSize="16" FontWeight="SemiBold" Height="40" HorizontalAlignment="Stretch" Command="{Binding EmergencyStopCommand}">
								<Button.Resources>
									<Style TargetType="Border">
										<Setter Property="CornerRadius" Value="4"/>
									</Style>
								</Button.Resources>
							</Button>
						</Border>

						<Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="1*"/>
									<ColumnDefinition Width="8"/>
									<ColumnDefinition Width="1*"/>
								</Grid.ColumnDefinitions>

								<RepeatButton Grid.Column="0" Content="升高" Delay="200" Interval="100" HorizontalAlignment="Stretch" Command="{Binding RaiseCommand}">
									<RepeatButton.Resources>
										<Style TargetType="Border">
											<Setter Property="CornerRadius" Value="4"/>
										</Style>
									</RepeatButton.Resources>
								</RepeatButton>

								<RepeatButton Grid.Column="2" Content="降低" Delay="200" Interval="100" HorizontalAlignment="Stretch" Command="{Binding LowerCommand}">
									<RepeatButton.Resources>
										<Style TargetType="Border">
											<Setter Property="CornerRadius" Value="4"/>
										</Style>
									</RepeatButton.Resources>
								</RepeatButton>
							</Grid>
						</Border>

						<Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="4" Padding="12">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="1*"/>
									<ColumnDefinition Width="8"/>
									<ColumnDefinition Width="1*"/>
								</Grid.ColumnDefinitions>

								<Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="*"/>
									</Grid.ColumnDefinitions>
									<TextBlock Grid.Column="0" Text="绝对位置:" VerticalAlignment="Center" Foreground="Gray" FontSize="12" Margin="0,0,8,0"/>
									<TextBlock Grid.Column="1" Text="{Binding CurrentMovePosition}" FontWeight="SemiBold" FontSize="14" Foreground="#0078D4" VerticalAlignment="Center" HorizontalAlignment="Center"/>
								</Grid>

								<Grid Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="*"/>
									</Grid.ColumnDefinitions>
									<TextBlock Grid.Column="0" Text="步长:" VerticalAlignment="Center" Foreground="Gray" FontSize="12" Margin="0,0,8,0"/>
									<TextBox Grid.Column="1" Text="{Binding MoveStep}" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="12" HorizontalAlignment="Stretch"/>
								</Grid>

								<Button Grid.Row="1" Grid.Column="0" Content="后退" Style="{DynamicResource AccentButtonStyle}" HorizontalAlignment="Stretch" Command="{Binding MoveBackwardCommand}">
									<Button.Resources>
										<Style TargetType="Border">
											<Setter Property="CornerRadius" Value="4"/>
										</Style>
									</Button.Resources>
								</Button>

								<Button Grid.Row="1" Grid.Column="2" Content="前进" Style="{DynamicResource AccentButtonStyle}" HorizontalAlignment="Stretch" Command="{Binding MoveForwardCommand}">
									<Button.Resources>
										<Style TargetType="Border">
											<Setter Property="CornerRadius" Value="4"/>
										</Style>
									</Button.Resources>
								</Button>
							</Grid>
						</Border>

					</StackPanel>
				</Border>

				<Grid Grid.Column="1">
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<Border Grid.Row="0" Margin="0,0,0,12" BorderBrush="#D1D1D1" BorderThickness="2" CornerRadius="8" Padding="16" Background="Transparent">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>
							<TextBlock Grid.Row="0" Text="报警日志" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
							<ListView Grid.Row="1" ItemsSource="{Binding AlarmLogs}" BorderThickness="0" Background="Transparent">
								<ListView.View>
									<GridView>
										<GridViewColumn Header="等级" Width="60" DisplayMemberBinding="{Binding Level}"/>
										<GridViewColumn Header="描述" Width="200" DisplayMemberBinding="{Binding Description}"/>
										<GridViewColumn Header="时间" Width="140" DisplayMemberBinding="{Binding Timestamp, StringFormat='yyyy/MM/dd HH:mm:ss'}"/>
										<GridViewColumn Header="来源" Width="80" DisplayMemberBinding="{Binding Source}"/>
									</GridView>
								</ListView.View>
							</ListView>
						</Grid>
					</Border>

					<Border Grid.Row="1" BorderBrush="#D1D1D1" BorderThickness="2" CornerRadius="8" Padding="16" Background="Transparent">
						<StackPanel>
							<TextBlock Text="系统诊断" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
							<TextBlock Text="{Binding DiagnosticText}" Foreground="#C62828" FontWeight="SemiBold"/>
						</StackPanel>
					</Border>
				</Grid>
			</Grid>
		</Grid>
	</Grid>
</Window>